{
  "appId": "com.weave.app",
  "productName": "Weave",
  "directories": {
    "buildResources": "assets",
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "native/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": ".env",
      "to": ".env"
    },
    {
      "from": "native/ocr/weave-ocr",
      "to": "native/ocr/weave-ocr"
    },
    {
      "from": "src/main/scripts/fetch_apple_contacts",
      "to": "native/contacts/fetch_apple_contacts"
    },
    {
      "from": "assets/icon-tray-template.svg",
      "to": "assets/icon-tray-template.svg"
    }
  ],
  "mac": {
    "target": [
      "dmg",
      "zip"
    ],
    "category": "public.app-category.productivity",
    "icon": "assets/icon.icns",
    "identity": null,
    "hardenedRuntime": false,
    "gatekeeperAssess": false
  },
  "dmg": {
    "title": "Weave",
    "contents": [
      {
        "x": 410,
        "y": 150,
        "type": "link",
        "path": "/Applications"
      },
      {
        "x": 130,
        "y": 150,
        "type": "file"
      }
    ],
    "window": {
      "width": 540,
      "height": 360
    }
  },
  "afterPack": "./scripts/after-pack.js"
}
